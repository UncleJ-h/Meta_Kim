{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-kim.dev/contracts/runtime-profile.schema.json",
  "title": "Meta_Kim Runtime Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "label",
    "projection",
    "activation"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supportsRepoProjection",
        "supportsLocalActivation",
        "assetTypes",
        "outputPaths"
      ],
      "properties": {
        "supportsRepoProjection": {
          "type": "boolean"
        },
        "supportsLocalActivation": {
          "type": "boolean"
        },
        "assetTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "outputPaths": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supportsGlobalSkillSync",
        "supportsGlobalDependencyInstall",
        "supportsGlobalHooks",
        "envKeys",
        "defaultHomeDir"
      ],
      "properties": {
        "supportsGlobalSkillSync": {
          "type": "boolean"
        },
        "supportsGlobalDependencyInstall": {
          "type": "boolean"
        },
        "supportsGlobalHooks": {
          "type": "boolean"
        },
        "envKeys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "defaultHomeDir": {
          "type": "string"
        }
      }
    }
  }
}
