{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-kim.dev/contracts/sync-manifest.schema.json",
  "title": "Meta_Kim Sync Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "supportedTargets",
    "defaultTargets",
    "canonicalRoots",
    "generatedTargets"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "availableTargets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "supportedTargets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "defaultTargets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "canonicalRoots": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "required": [
        "agents",
        "skills",
        "runtimeAssets",
        "contracts"
      ]
    },
    "generatedTargets": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}
